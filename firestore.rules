rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() && (request.auth.uid == "bn6vKOGvIeUdF91P0fzMEbFZfGr2" || request.auth.uid == "OUJAuK34FoTpFyJqgOVjCH9c4Kf1");
    }
    function isCommunityOwnerOrAdmin(communityId) {
      let memberDoc = get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));
      let commDoc = get(/databases/$(database)/documents/communities/$(communityId));
      return isAuth() && (
        commDoc.data.creatorUid == request.auth.uid ||
        (memberDoc.data.role == "owner") ||
        (memberDoc.data.role == "admin")
      );
    }

    // Allow all reads for everyone
    match /{document=**} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Community members — only owner/admin can change roles
    match /communities/{communityId}/members/{memberId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (
        // User can update their own join data
        request.auth.uid == memberId ||
        // Owner/admin can update any member's role
        isCommunityOwnerOrAdmin(communityId) ||
        isAdmin()
      );
      allow delete: if isAuth() && (
        request.auth.uid == memberId ||
        isCommunityOwnerOrAdmin(communityId) ||
        isAdmin()
      );
    }

    // Only owner or admin can delete posts
    match /posts/{postId} {
      allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // Only owner or admin can delete comments
    match /posts/{postId}/comments/{commentId} {
      allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // Only owner or admin can delete forum threads/replies
    match /forums/{forumId}/threads/{threadId} {
      allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }
    match /forums/{forumId}/threads/{threadId}/replies/{replyId} {
      allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // Reports: only admins can read/update/delete
    match /reports/{reportId} {
      allow read, update, delete: if isAdmin();
    }

    // Custom feeds — only owner can read/write their own feeds
    match /users/{userId}/customFeeds/{feedId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
  }
}
