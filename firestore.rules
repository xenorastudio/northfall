rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() && (request.auth.uid == "bn6vKOGvIeUdF91P0fzMEbFZfGr2" || request.auth.uid == "OUJAuK34FoTpFyJqgOVjCH9c4Kf1");
    }
    function isCommunityStaff(communityId) {
      // For posts with communityDocId, use that instead of the display name
      let commId = ('communityDocId' in resource.data && resource.data.communityDocId != "")
        ? resource.data.communityDocId
        : communityId;
      let commDoc = get(/databases/$(database)/documents/communities/$(commId));
      let memberDoc = get(/databases/$(database)/documents/communities/$(commId)/members/$(request.auth.uid));
      return isAuth() && (
        commDoc.data.creatorUid == request.auth.uid ||
        memberDoc.data.role == "owner" ||
        memberDoc.data.role == "admin" ||
        memberDoc.data.role == "moderator" ||
        memberDoc.data.permissions.managePosts == true
      );
    }
    function postCommunityDocId(postData) {
      return ('communityDocId' in postData && postData.communityDocId != "")
        ? postData.communityDocId
        : postData.community;
    }
    function canPostInTargetCommunity() {
      let isProfileTarget = !('community' in request.resource.data)
        || request.resource.data.community == ""
        || ('postTarget' in request.resource.data && request.resource.data.postTarget == "profile");
      if (isProfileTarget) return true;
      let commId = postCommunityDocId(request.resource.data);
      let commDoc = get(/databases/$(database)/documents/communities/$(commId));
      if (!commDoc.exists()) return isAuth();
      let rawType = ('communityType' in commDoc.data) ? commDoc.data.communityType : "";
      let commType = rawType == "private" ? "private"
        : rawType == "restricted" ? "restricted"
        : (('modLevel' in commDoc.data) ? (commDoc.data.modLevel == "moderate" ? "restricted" : commDoc.data.modLevel == "restrict" ? "private" : "public") : "public");
      if (commType == "public") return true;
      if (commType == "restricted") {
        let memberDoc = get(/databases/$(database)/documents/communities/$(commId)/members/$(request.auth.uid));
        return isAuth() && (
          commDoc.data.creatorUid == request.auth.uid ||
          (memberDoc.exists() && (
            memberDoc.data.role == "admin" ||
            memberDoc.data.role == "moderator" ||
            memberDoc.data.permissions.managePosts == true
          ))
        );
      }
      // private
      let memberDoc = get(/databases/$(database)/documents/communities/$(commId)/members/$(request.auth.uid));
      return isAuth() && (memberDoc.exists() || commDoc.data.creatorUid == request.auth.uid);
    }

    function isOwner(resource) {
      return request.auth.uid == resource.data.ownerId;
    }
    function isFeedEditor(data) {
      return isAuth() && (
        ('editorUids' in data && data.editorUids is list && request.auth.uid in data.editorUids) ||
        (data.editors is list && data.editors.size() > 0 && !(data.editors[0] is map) && request.auth.uid in data.editors)
      );
    }
    function isEditor(resource) {
      return isFeedEditor(resource.data);
    }

    function validCategoryField() {
      return !('category' in request.resource.data)
        || (request.resource.data.category is string
            && request.resource.data.category.size() > 0
            && request.resource.data.category.size() <= 80);
    }

    function validIsMatureField() {
      return !('isMature' in request.resource.data)
        || request.resource.data.isMature is bool;
    }

    function validMutedCommunitiesField() {
      return !('mutedCommunities' in request.resource.data)
        || request.resource.data.mutedCommunities is list;
    }

    function validCommunityMutesField() {
      return !('communityMutes' in request.resource.data)
        || request.resource.data.communityMutes is map;
    }

    function validUserInterestsField() {
      return !('userInterests' in request.resource.data)
        || (request.resource.data.userInterests is list
            && request.resource.data.userInterests.size() <= 50);
    }

    function validCommunityTagsField() {
      return !('tags' in request.resource.data)
        || request.resource.data.tags is list;
    }

    function isProfileStatBump() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['karma'])
        || changed.hasOnly(['forumKarma'])
        || changed.hasOnly(['xp'])
        || changed.hasOnly(['commentCount'])
        || changed.hasOnly(['postCount'])
        || changed.hasOnly(['forumXp'])
        || changed.hasOnly(['commentCount', 'xp'])
        || changed.hasOnly(['forumXp', 'postCount'])
        || changed.hasOnly(['postCount', 'xp']);
    }

    // قراءة عامة — بدون كتابة شاملة (كانت تسمح لأي مستخدم بتعديل أي وثيقة)
    match /{document=**} {
      allow read: if true;
    }

    match /system/{docId} {
      allow read: if true;
      allow create: if request.resource.data.active == false;
      allow update: if isAdmin()
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['active'])
            && request.resource.data.active == false);
    }

    match /invites/{inviteId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

    match /communities/{communityId} {
      allow create: if isAuth() && validCategoryField() && validIsMatureField() && validCommunityTagsField();
      allow update: if isAuth() && validCategoryField() && validIsMatureField() && validCommunityTagsField();
      allow delete: if isAuth() && resource.data.creatorUid == request.auth.uid;
    }

    match /users/{userId} {
      allow update: if isAuth() && (
        (request.auth.uid == userId && validMutedCommunitiesField() && validCommunityMutesField() && validUserInterestsField())
        || isAdmin()
        || isProfileStatBump()
      );
      allow create: if isAuth() && request.auth.uid == userId && validMutedCommunitiesField() && validCommunityMutesField() && validUserInterestsField();
    }

    match /users/{userId}/communities/{communityId} {
      allow create, update: if isAuth() && request.auth.uid == userId
        && (!('isFavorite' in request.resource.data) || request.resource.data.isFavorite is bool);
      allow delete: if isAuth() && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/communities/$(communityId)).data.creatorUid == request.auth.uid
      );
    }

    match /users/{userId}/hiddenPosts/{postId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
    match /users/{userId}/negativeSignals/{signalId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
    match /users/{userId}/categoryAffinities/{affinityId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    function isViewCountOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
        && request.resource.data.views == resource.data.get('views', 0) + 1;
    }

    function isVoteCountOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes']);
    }

    function isCommentCountOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount']);
    }

    // Posts — staff can delete/update any post in their community
    match /posts/{postId} {
      allow create: if isAuth() && request.resource.data.authorUid == request.auth.uid && canPostInTargetCommunity();
      allow delete: if isAuth() && (
        resource.data.authorUid == request.auth.uid ||
        isAdmin() ||
        isCommunityStaff(resource.data.community)
      );
      allow update: if isAuth() && (
        resource.data.authorUid == request.auth.uid ||
        isAdmin() ||
        isCommunityStaff(resource.data.community)
      ) || isViewCountOnlyUpdate() || isVoteCountOnlyUpdate() || isCommentCountOnlyUpdate();
    }

    match /posts/{postId}/votes/{uid} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // Comments — staff can delete
    match /posts/{postId}/comments/{commentId} {
      allow create: if isAuth() && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.authorUid == request.auth.uid ||
        isAdmin()
      ) || isVoteCountOnlyUpdate();
      allow delete: if isAuth() && (
        resource.data.authorUid == request.auth.uid ||
        isAdmin()
      );
    }

    match /posts/{postId}/comments/{commentId}/votes/{uid} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == uid;
    }

    match /users/{userId}/notifications/{notifId} {
      allow read, update, delete: if isAuth() && request.auth.uid == userId;
      allow create: if isAuth();
    }

    match /users/{userId}/saved/{savedId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    match /users/{userId}/following/{otherId} {
      allow read: if true;
      allow write: if isAuth() && (request.auth.uid == userId || request.auth.uid == otherId);
    }

    match /users/{userId}/followers/{otherId} {
      allow read: if true;
      allow write: if isAuth() && (request.auth.uid == userId || request.auth.uid == otherId);
    }

    match /users/{userId}/savedThreads/{threadId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    match /users/{userId}/games/{docId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // Community members
    match /communities/{communityId}/members/{memberId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (
        request.auth.uid == memberId ||
        isCommunityStaff(communityId) ||
        isAdmin()
      );
      allow delete: if isAuth() && (
        request.auth.uid == memberId ||
        isCommunityStaff(communityId) ||
        isAdmin()
      );
    }

    // Forum threads/replies
    match /forums/{forumId}/threads/{threadId} {
      allow create: if isAuth() && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuth() && (resource.data.authorUid == request.auth.uid || isAdmin())
        || isVoteCountOnlyUpdate();
      allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }
    match /forums/{forumId}/threads/{threadId}/replies/{replyId} {
      allow create: if isAuth() && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuth() && (resource.data.authorUid == request.auth.uid || isAdmin())
        || isVoteCountOnlyUpdate();
      allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }
    match /forums/{forumId}/threads/{threadId}/votes/{uid} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // Reports
    match /reports/{reportId} {
      allow create: if isAuth()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.type in ['post', 'comment']
        && request.resource.data.status == 'pending'
        && request.resource.data.category is string
        && request.resource.data.category.size() <= 64
        && request.resource.data.targetId is string
        && request.resource.data.targetId.size() > 0
        && request.resource.data.targetId.size() <= 200
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 120
        && request.resource.data.createdAt is string
        && (!('details' in request.resource.data) || (request.resource.data.details is string && request.resource.data.details.size() <= 2000));
      allow read, update, delete: if isAdmin();
    }

    // Custom feeds — private to owner
    match /users/{userId}/customFeeds/{feedId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ─── Shared Custom Feeds (top-level collection) ──────────
    match /custom_feeds/{feedId} {
      allow create: if isAuth();
      allow read: if isAuth();
      allow update: if isAuth() && (
        isOwner(resource) ||
        (isEditor(resource)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["communities", "bannerUrl", "iconUrl", "showBannerBg", "name", "isPrivate", "showOnProfile", "editors", "editorUids"]))
      );
      allow delete: if isAuth() && isOwner(resource);
    }
  }
}
