rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: authenticated user
    function isAuth() {
      return request.auth != null;
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId;
    }

    // Users notifications
    match /users/{userId}/notifications/{notifId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid == userId;
      allow delete: if isAuth() && request.auth.uid == userId;
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || request.auth.uid == "bn6vKOGvIeUdF91P0fzMEbFZfGr2");

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth();
        allow update: if isAuth() && (resource.data.authorUid == request.auth.uid || request.auth.uid == "bn6vKOGvIeUdF91P0fzMEbFZfGr2");
        allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || request.auth.uid == "bn6vKOGvIeUdF91P0fzMEbFZfGr2");
      }
    }

    // Forums collection
    match /forums/{forumId} {
      allow read: if true;
      allow write: if isAuth();

      match /threads/{threadId} {
        allow read: if true;
        allow create: if isAuth();
        allow update: if isAuth();
        allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || request.auth.uid == "bn6vKOGvIeUdF91P0fzMEbFZfGr2");

        match /replies/{replyId} {
          allow read: if true;
          allow create: if isAuth();
          allow update: if isAuth();
          allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || request.auth.uid == "bn6vKOGvIeUdF91P0fzMEbFZfGr2");
        }
      }
    }

    // Reports collection
    match /reports/{reportId} {
      allow create: if isAuth();
      allow read, update, delete: if isAuth() && request.auth.uid == "bn6vKOGvIeUdF91P0fzMEbFZfGr2";
    }

    // Communities
    match /communities/{commId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Chat messages
    match /chats/{chatId} {
      allow read, write: if isAuth();
    }

    // Block all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
