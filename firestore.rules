rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() && (request.auth.uid == "bn6vKOGvIeUdF91P0fzMEbFZfGr2" || request.auth.uid == "OUJAuK34FoTpFyJqgOVjCH9c4Kf1");
    }

    // Default: allow authenticated read, deny write
    match /{document=**} {
      allow read: if true;
    }

    // Users
    match /users/{userId} {
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId;
      allow delete: if isAuth() && request.auth.uid == userId;
    }

    // Posts
    match /posts/{postId} {
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // Reports
    match /reports/{reportId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

    // Forums
    match /forums/{forumId}/{collection}/{docId} {
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }
  }
}
