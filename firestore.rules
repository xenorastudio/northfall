rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() && (request.auth.uid == "bn6vKOGvIeUdF91P0fzMEbFZfGr2" || request.auth.uid == "OUJAuK34FoTpFyJqgOVjCH9c4Kf1");
    }
    function isCommunityStaff(communityId) {
      let commDoc = get(/databases/$(database)/documents/communities/$(communityId));
      let memberDoc = get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));
      return isAuth() && (
        commDoc.data.creatorUid == request.auth.uid ||
        memberDoc.data.role == "owner" ||
        memberDoc.data.role == "admin" ||
        memberDoc.data.role == "moderator" ||
        memberDoc.data.permissions.managePosts == true ||
        memberDoc.data.permissions.manageSettings == true
      );
    }

    function isOwner(resource) {
      return request.auth.uid == resource.data.ownerId;
    }
    function isFeedEditor(data) {
      return isAuth() && (
        ('editorUids' in data && data.editorUids is list && request.auth.uid in data.editorUids) ||
        (data.editors is list && data.editors.size() > 0 && !(data.editors[0] is map) && request.auth.uid in data.editors)
      );
    }
    function isEditor(resource) {
      return isFeedEditor(resource.data);
    }

    function validCategoryField() {
      return !('category' in request.resource.data)
        || (request.resource.data.category is string
            && request.resource.data.category.size() > 0
            && request.resource.data.category.size() <= 80);
    }

    function validIsMatureField() {
      return !('isMature' in request.resource.data)
        || request.resource.data.isMature is bool;
    }

    function validMutedCommunitiesField() {
      return !('mutedCommunities' in request.resource.data)
        || request.resource.data.mutedCommunities is list;
    }

    function validCommunityMutesField() {
      return !('communityMutes' in request.resource.data)
        || request.resource.data.communityMutes is map;
    }

    function validUserInterestsField() {
      return !('userInterests' in request.resource.data)
        || (request.resource.data.userInterests is list
            && request.resource.data.userInterests.size() <= 50);
    }

    function validOnboardingFields() {
      return (!('onboardingCompleted' in request.resource.data) || request.resource.data.onboardingCompleted is bool)
        && (!('onboardingGender' in request.resource.data) || request.resource.data.onboardingGender == null || request.resource.data.onboardingGender is string)
        && (!('onboardingCategories' in request.resource.data) || request.resource.data.onboardingCategories is list)
        && (!('onboardingTags' in request.resource.data) || request.resource.data.onboardingTags is list)
        && (!('interestTagWeights' in request.resource.data) || request.resource.data.interestTagWeights is map);
    }

    function validCommunityTagsField() {
      return !('tags' in request.resource.data)
        || request.resource.data.tags is list;
    }

    function isGamificationUserPatch() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['karma'])
        || keys.hasOnly(['forumKarma'])
        || keys.hasOnly(['forumXp'])
        || keys.hasOnly(['commentCount'])
        || keys.hasOnly(['xp'])
        || keys.hasOnly(['postCount'])
        || keys.hasOnly(['lastSeen'])
        || keys.hasOnly(['forumXp', 'postCount'])
        || keys.hasOnly(['commentCount', 'xp']);
    }

    // قراءة عامة فقط — لا كتابة افتراضية لأي مسار
    match /{document=**} {
      allow read: if true;
    }

    match /communities/{communityId} {
      allow create: if isAuth() && validCategoryField() && validIsMatureField() && validCommunityTagsField();
      allow update: if isAuth() && validCategoryField() && validIsMatureField() && validCommunityTagsField();
    }

    match /users/{userId} {
      allow update: if isAuth() && (
        isAdmin() ||
        isGamificationUserPatch() ||
        (request.auth.uid == userId && validMutedCommunitiesField() && validCommunityMutesField() && validUserInterestsField() && validOnboardingFields())
      );
      allow create: if isAuth() && request.auth.uid == userId && validMutedCommunitiesField() && validCommunityMutesField() && validUserInterestsField() && validOnboardingFields();
    }

    match /users/{userId}/onboarding/{docId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    match /users/{userId}/communities/{communityId} {
      allow write: if isAuth() && request.auth.uid == userId
        && (!('isFavorite' in request.resource.data) || request.resource.data.isFavorite is bool);
    }

    match /users/{userId}/customFeeds/{feedId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    match /users/{userId}/following/{targetId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth() && request.auth.uid == userId;
    }

    match /users/{userId}/followers/{followerId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth();
    }

    match /users/{userId}/saved/{postId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    match /users/{userId}/savedThreads/{threadId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    match /users/{userId}/notifications/{notifId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow create: if isAuth();
      allow update, delete: if isAuth() && request.auth.uid == userId;
    }

    match /users/{userId}/games/{docId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    match /users/{userId}/hiddenPosts/{postId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
    match /users/{userId}/negativeSignals/{signalId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
    match /users/{userId}/categoryAffinities/{affinityId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    match /system/maintenance {
      allow read: if true;
      allow write: if isAdmin();
    }

    function isViewCountOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
        && request.resource.data.views == resource.data.get('views', 0) + 1;
    }

    match /posts/{postId} {
      allow create: if isAuth()
        && request.resource.data.authorUid == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.authorUid == request.auth.uid ||
        isAdmin() ||
        isCommunityStaff(resource.data.community)
      );
      allow update: if isAuth() && (
        resource.data.authorUid == request.auth.uid ||
        isAdmin() ||
        isCommunityStaff(resource.data.community)
      ) || isViewCountOnlyUpdate();
    }

    match /posts/{postId}/comments/{commentId} {
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.authorUid == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.authorUid == request.auth.uid ||
        isAdmin()
      );
    }

    match /posts/{postId}/votes/{voterId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == voterId;
    }

    match /posts/{postId}/comments/{commentId}/votes/{voterId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == voterId;
    }

    match /reports/{reportId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

    match /invites/{inviteId} {
      allow create: if isAuth();
      allow read: if isAuth();
    }

    match /communities/{communityId}/members/{memberId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (
        request.auth.uid == memberId ||
        isCommunityStaff(communityId) ||
        isAdmin()
      );
      allow delete: if isAuth() && (
        request.auth.uid == memberId ||
        isCommunityStaff(communityId) ||
        isAdmin()
      );
    }

    match /forums/{forumId}/threads/{threadId} {
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.authorUid == request.auth.uid;
      allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }
    match /forums/{forumId}/threads/{threadId}/replies/{replyId} {
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.authorUid == request.auth.uid;
      allow delete: if isAuth() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    match /custom_feeds/{feedId} {
      allow create: if isAuth();
      allow read: if isAuth();
      allow update: if isAuth() && (
        isOwner(resource) ||
        (isEditor(resource)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["communities", "bannerUrl", "iconUrl", "showBannerBg", "name", "isPrivate", "showOnProfile", "editors", "editorUids"]))
      );
      allow delete: if isAuth() && isOwner(resource);
    }
  }
}
